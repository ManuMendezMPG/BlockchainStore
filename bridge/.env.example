# /bridge/.env.example
# Copia este fichero a `.env` si lo necesitas. `.env` está en .gitignore.
#
# Estado actual: el servidor (server.js) NO usa dependencias ni carga un .env;
# solo lee la variable de entorno PORT directamente. La configuración de la
# blockchain (RPC, dirección del contrato, chain id) vive de momento como
# CONSTANTES en public/app.js (es código de FRONTEND, se ejecuta en el navegador).
#
# Este fichero documenta qué variables harían falta si más adelante movemos esa
# configuración al backend o inyectamos config al frontend desde el servidor.

# Puerto del servidor estático local.
PORT=8787

# URL del nodo RPC (Anvil local). Hoy está hardcodeada en app.js como RPC_URL.
RPC_URL=http://127.0.0.1:8545

# Dirección del contrato GameStore desplegado. Hoy está en app.js como
# CONTRACT_ADDRESS. En Anvil es determinista (primer deploy de la cuenta #0).
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Chain ID esperado; el front avisa si MetaMask está en otra red. 31337 = Anvil.
CHAIN_ID=31337
