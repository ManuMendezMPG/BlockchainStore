# /bridge/.env.example
# Copia este fichero a `.env` y rellena los valores reales.
# `.env` está en .gitignore: NUNCA lo commitees.

# Puerto en el que el servidor local escucha al juego de Unreal.
PORT=8787

# URL del nodo RPC para consultas de solo-lectura (balances, eventos).
# Las transacciones que firman se hacen vía MetaMask en el navegador,
# pero el servidor puede necesitar leer estado on-chain.
RPC_URL=

# Dirección del contrato ERC-1155 ya desplegado al que apunta el puente.
CONTRACT_ADDRESS=

# Chain ID esperado; el front avisa si MetaMask está en otra red.
# Ej.: 11155111 (Sepolia), 31337 (Anvil local).
CHAIN_ID=

# (Opcional) Origen permitido para CORS si el front se sirve aparte.
ALLOWED_ORIGIN=http://localhost:8787
