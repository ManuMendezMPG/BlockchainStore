# /contracts/.env.example
# Copia este fichero a `.env` y rellena los valores reales.
# `.env` está en .gitignore: NUNCA lo commitees.

# URL del nodo RPC de la red destino (testnet/mainnet/local).
# Ej.: Anvil local -> http://127.0.0.1:8545
RPC_URL=

# Clave privada de la cuenta que despliega los contratos.
# Usa una cuenta de pruebas SIN fondos reales para desarrollo.
# (forge la lee con --private-key $PRIVATE_KEY)
# En Anvil, puedes usar una de las claves de prueba que imprime al arrancar.
PRIVATE_KEY=

# API key para verificar el contrato en un explorador (Etherscan, etc.).
# Opcional; solo si vas a verificar el código fuente on-chain.
ETHERSCAN_API_KEY=

# (Opcional) Chain ID de la red destino, p. ej. 11155111 para Sepolia,
# o 31337 para Anvil local.
CHAIN_ID=
